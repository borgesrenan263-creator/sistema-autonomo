# Sistema Autônomo — exemplo seguro

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=4567

# Gemini
GEMINI_API_KEY=cole_sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash

# IA
AI_MIN_DELIVERY_CHARS=1200
AI_MIN_PROPOSAL_CHARS=1000

# Worker
RESCAN_INTERVAL_SECONDS=300

# Pix
PIX_PROVIDER=manual
PIX_WEBHOOK_SECRET=trocar_em_producao

# Email
EMAIL_PROVIDER=manual
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# WhatsApp
WHATSAPP_PROVIDER=manual
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Pix Webhook Provider
PIX_PROVIDER=webhook
PIX_WEBHOOK_SECRET=troque_este_segredo_em_producao

# Response Inbox Webhook
RESPONSE_WEBHOOK_SECRET=trocar_em_producao
